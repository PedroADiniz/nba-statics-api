{
  "name": "nba-h2h-api",
  "version": "1.0.0",
  "description": "NBA Head-to-Head Analyzer — RESTful API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate:developer": "prisma migrate dev --name init",
    "db:seed:developer": "ts-node prisma/seed.ts",
    "db:setup:developer": "prisma migrate dev --name init && ts-node prisma/seed.ts",
    "db:migrate:production": "prisma migrate deploy",
    "db:seed:production": "ts-node prisma/seed.ts",
    "db:setup:production": "prisma migrate deploy && ts-node prisma/seed.ts",
    "docker-up:api-mysql:developer": "docker compose -f docker-compose.api.mysql.developer.yml up -d",
    "docker-down:api-mysql:developer": "docker compose -f docker-compose.api.mysql.developer.yml down",
    "docker-up:api-postgresql:developer": "docker compose -f docker-compose.api.postgresql.developer.yml up -d",
    "docker-down:api-postgresql:developer": "docker compose -f docker-compose.api.postgresql.developer.yml down",
    "docker-up:api-postgresql:production": "docker compose -f docker-compose.api.postgresql.production.yml up -d",
    "docker-down:api-postgresql:production": "docker compose -f docker-compose.api.postgresql.production.yml down",
    "docker-up:api-mysql:production": "docker compose -f docker-compose.api.mysql.production.yml up -d",
    "docker-down:api-mysql:production": "docker compose -f docker-compose.api.mysql.production.yml down",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "prisma": "^5.16.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}