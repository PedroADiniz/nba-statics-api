# Engine do banco: postgresql ou mysql
DATABASE_ENGINE="mysql"
# Connection string para execução local (sem Docker) — sobreposta pelo compose ao usar Docker
DATABASE_URL="mysql://nba_user:nba_pass123@localhost:3306/nba_h2h"

# Credenciais do banco — Docker Compose dev MySQL
MYSQL_DATABASE=nba_h2h
MYSQL_USER=nba_user
MYSQL_PASSWORD=nba_pass123
MYSQL_ROOT_PASSWORD=root123
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci

# Credenciais do banco — Docker Compose dev PostgreSQL
POSTGRES_DB=nba_h2h
POSTGRES_USER=nba_user
POSTGRES_PASSWORD=nba_pass123

# Credenciais do banco — interpolação da DATABASE_URL no compose dev
DB_NAME=nba_h2h
DB_USER=nba_user
DB_PASSWORD=nba_pass123

# Server
PORT=3000
NODE_ENV=development

# Security — chave usada no header "x-api-key" para proteger os endpoints
API_KEY=troque-por-um-valor-secreto-seguro

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# NBA Stats API (stats.nba.com — sem chave, mas respeitamos o rate limit)
NBA_STATS_BASE_URL=https://stats.nba.com/stats
NBA_REQUEST_DELAY_MS=700

# CORS — origens permitidas separadas por vírgula (use * para liberar tudo em dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
