# Server
PORT=3000
NODE_ENV=production

# Security — chave usada no header "x-api-key" para proteger os endpoints
API_KEY=troque-por-um-valor-secreto-seguro

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# NBA Stats API (stats.nba.com — sem chave, mas respeitamos o rate limit)
NBA_STATS_BASE_URL=https://stats.nba.com/stats
NBA_REQUEST_DELAY_MS=700

# CORS — origens permitidas separadas por vírgula (ex: https://meuapp.com,https://www.meuapp.com)
CORS_ORIGINS=https://meudominio.com

# Database engine — deve corresponder ao compose usado (mysql ou postgresql)
# docker-compose.api.mysql.production.yml     → DATABASE_ENGINE=mysql
# docker-compose.api.postgresql.production.yml → DATABASE_ENGINE=postgresql
DATABASE_ENGINE=postgresql

# URL de conexão — ajuste conforme o engine escolhido
# Atenção: DATABASE_URL e DATABASE_ENGINE devem usar o mesmo engine
# PostgreSQL:
DATABASE_URL=postgresql://nba_user:troque-por-uma-senha-segura@db:5432/nba_h2h

# MySQL:
# DATABASE_ENGINE=mysql
# DATABASE_URL=mysql://nba_user:troque-por-uma-senha-segura@db:3306/nba_h2h

# Credenciais do banco — Docker Compose prod MySQL
MYSQL_DATABASE=nba_h2h
MYSQL_USER=nba_user
MYSQL_PASSWORD=troque-por-uma-senha-segura
MYSQL_ROOT_PASSWORD=troque-por-uma-senha-root-segura

# Credenciais do banco — Docker Compose prod PostgreSQL
POSTGRES_DB=nba_h2h
POSTGRES_USER=nba_user
POSTGRES_PASSWORD=troque-por-uma-senha-segura


